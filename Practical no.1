Q no.1.1.2
import math
def digit(num):
	if 1<=num<=9:
		print(num*num)
	elif 10<=num<=99:
		print(f"{math.sqrt(num):.2f}")
	elif 100<=num<=999:
		print(f"{math.pow(num,(1/3)):.2f}")
	else:
		print("Invalid")
num=int(input())
digit(num)

Q no.1.1.3
from datetime import date
# Read input dtaes from user
date_str1 = input()
date_str2 = input()

# Convert date strings to date objects 
# Splitting the string and converting components to integers
y1, m1, d1 = map(int, date_str1.split('-'))
y2, m2, d2 = map(int, date_str2.split('-'))

date1 = date(y1, m1, d1)
date2 = date(y2, m2, d2)

# Calculate the difference between the dates
# The result is a timedelta object
delta = date2 - date1

# The number of days is the 'days' attribute of the timedelta object
print(delta.days)

